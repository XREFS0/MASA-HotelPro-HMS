<Window x:Class="MasaHotelPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:MasaHotelPro"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="768" Width="1366"
        Icon="logo.png"
        Background="#F8FAFC"
        TextElement.Foreground="#0F172A"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    
    <Window.Resources>
        <!-- Light SaaS Navigation Button -->
        <Style x:Key="LightNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="15,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="content" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <Setter TargetName="content" Property="HorizontalAlignment" Value="Center"/>
                                <Setter TargetName="content" Property="Margin" Value="0,0"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E0E7FF"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Selected Navigation Button -->
        <Style x:Key="LightNavButtonSelected" TargetType="Button" BasedOn="{StaticResource LightNavButton}">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#2563EB"/>
        </Style>

        <!-- Sidebar Text Style (Hides when Collapsed) -->
        <Style x:Key="SidebarTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="15,0,0,0"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar (White) -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="DiamondStone" Width="28" Height="28" Foreground="#2563EB" VerticalAlignment="Center"/>
                    <TextBlock Text="MASA Pro" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="10,0,0,0"/>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="0,10">
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Dashboard" Style="{StaticResource LightNavButtonSelected}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Reservations" Style="{StaticResource LightNavButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarCheckOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Reservations" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Rooms" Style="{StaticResource LightNavButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DoorOpen" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Rooms" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Guests" Style="{StaticResource LightNavButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Guests" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Employees" Style="{StaticResource LightNavButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountTie" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Staff" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Housekeeping" Style="{StaticResource LightNavButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Broom" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Housekeeping" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Billing" Style="{StaticResource LightNavButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ReceiptTextOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Billing &amp; Invoices" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Reports" Style="{StaticResource LightNavButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ChartPie" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Reports" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}" CommandParameter="Settings" Style="{StaticResource LightNavButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CogOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Settings" Style="{StaticResource SidebarTextStyle}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
                

                <Button Grid.Row="2" Command="{Binding ToggleSidebarCommand}" Margin="15,10,15,20" Background="Transparent" BorderThickness="0" Foreground="#475569" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Width="20" Height="20" VerticalAlignment="Center">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="ChevronLeft"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                            <Setter Property="Kind" Value="ChevronRight"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                        <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Collapse"/>
                                    <Setter Property="Margin" Value="8,0,0,0"/>
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- TopBar -->
            <Grid Grid.Row="0" Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Welcome back, Masa!" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text=" 👋" FontSize="24"/>
                    </StackPanel>
                    <TextBlock Text="Here's what's happening today." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Removed Bell and Exit buttons per user request -->
                </StackPanel>
            </Grid>
            
            <!-- Dynamic View Content Container -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
